# Eval + gateway configuration — copy to .env and fill in:
#
#   cp .env.example .env
#
# One .env serves both halves of the local setup:
#   • promptfoo (the eval client) reads it automatically on `npm run eval`.
#     `npm run prompts:check` / `npm run prompts:index` are offline and need none of it.
#   • the local LiteLLM gateway (`make gateway`) reads it via docker compose.
#
# All model calls route through the gateway, so the runner and judge models in
# evals/promptfoo.base.yaml / evals/judge-*.yaml can be any provider the gateway
# serves (Anthropic, OpenAI, Google, BYOK), behind one key and one spend log.

# --- promptfoo: the eval client ---
# Base URL of the gateway (dashboard at <base_url>/ui).
LITELLM_BASE_URL=http://localhost:4000
# Virtual key issued by the gateway dashboard (Virtual Keys → Create New Key;
# shown once on create). Grant it every runner + judge model you eval with.
LITELLM_API_KEY=

# NOTE: which models the suite runs against is NOT set here — it lives in
# version-controlled YAML:
#   • runner matrix → evals/promptfoo.base.yaml  (- id: litellm:chat:<model_name>)
#   • judges        → evals/judge-primary.yaml / evals/judge-secondary.yaml (id:)
# Each <model_name> must exist in gateway/litellm-config.yaml and be granted to
# the virtual key above.

# Where promptfoo keeps its local store — the SQLite run history behind
# `npm run eval:view`. Pointing it at the repo (instead of the default
# ~/.promptfoo) keeps a clone self-contained and the history on one machine in
# one place. .promptfoo/ is gitignored. `npm run eval` defaults to this even if
# unset; set it here so `npm run eval:view` reads the same store.
PROMPTFOO_CONFIG_DIR=.promptfoo

# --- eval sampling + ship gate (scripts/gate.js) ---
# Each cell is sampled EVAL_SAMPLES times (promptfoo --repeat) so the gate judges
# a distribution, not one noisy judge score. The gate then requires the
# foundation column to clear an absolute quality floor AND beat its strongest
# baseline by a margin, both on the neutral (Opus) judge. `make eval` exits
# non-zero on a FAIL (override with `node scripts/eval.js --no-gate`). Defaults
# shown — raise EVAL_SAMPLES if cells come back noisy (large ±sd / WARN).
EVAL_SAMPLES=3
EVAL_MIN_QUALITY=0.7
EVAL_MIN_MARGIN=0.1
EVAL_MAX_STDEV=0.15

# --- local LiteLLM gateway (make gateway) ---
# Master key — protects the proxy + dashboard. Any strong "sk-..." string you pick.
LITELLM_MASTER_KEY=sk-
# Upstream provider keys the gateway calls. The suite's active models need
# Anthropic (runner + primary judge) and OpenAI (secondary judge); Gemini is
# only for the optional runner in evals/promptfoo.base.yaml.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# AWS Bedrock (optional) — needed only if gateway/litellm-config.yaml has a
# bedrock/* model. Either fill in static keys here, or leave them blank and run
# the gateway under an IAM role / instance profile (boto3 default chain).
# AWS_SESSION_TOKEN is only for temporary (STS / SSO) credentials. Enable each
# model first in the Bedrock console → "Model access" for AWS_REGION_NAME.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION_NAME=us-east-1
# Dashboard login (optional — defaults to admin/admin).
UI_USERNAME=admin
UI_PASSWORD=admin
